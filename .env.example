# Server Configuration
PORT=5000
MONGO_URI=mongodb://localhost:27017/fintrack
JWT_SECRET=your_jwt_secret_key_here

# Email / SMTP Configurations (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM="FinTrack Advisor" <your_email@gmail.com>
EMAIL_ENABLED=true

# Angel One SmartAPI Configurations (Optional for Live Stocks integration)
ANGEL_ONE_CLIENT_ID=your_client_id
ANGEL_ONE_PASSWORD=your_password
ANGEL_ONE_API_KEY=your_api_key
ANGEL_ONE_TOTP_SECRET=your_totp_secret_key

# Local LLM Configuration (e.g. Ollama for AI Financial Newspaper generation)
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=llama3
